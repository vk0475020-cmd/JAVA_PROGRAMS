import java.util.*;
class Solution {
    public boolean isPalindrome(int x) {
        int r,s=0;
        int t=x;
        if(x<0){
            return false;
        }
        else{
                while(x!=0){
                r=x%10;
                s=s*10+r;
                x/=10;
                
            }return(t==s);
        }
    }
}
