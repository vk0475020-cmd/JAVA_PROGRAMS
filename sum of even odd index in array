public class Hello {
    public static void main(String[] args) {
        int[] arr={1,12,23,45,64,3,56,7};
        int e=0,o=0;
        for(int i=0;i<arr.length;i++){
            if(arr[i]%2==0){
                e=e+arr[i];

            }else{
                o=o+arr[i];
            }
        }System.out.println(e);
        System.out.println(o);

        
    }
}
