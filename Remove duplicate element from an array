import java.util.*;

public class Hello {
    public static void main(String[] args) {
        int[] arr = {7,7,7,7,7};
        Arrays.sort(arr);
        
        if(arr.length > 0) {
            System.out.print(arr[0] + " ");
            for(int i = 1; i < arr.length; i++) {
                if(arr[i] != arr[i-1]) {
                    System.out.print(arr[i] + " ");
                }
            }
        }
    }
}
